generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SystemSetting {
  id                  String   @id @default("1")
  siteTitle           String   @default("Cresce Reels - Comprar Visualizações Instagram")
  siteDescription     String   @default("Aumente seu engajamento no Reels de forma rápida e segura.")
  siteKeywords        String   @default("comprar visualizações, instagram reels, engajamento, redes sociais")
  faviconUrl          String?
  whatsappNumber      String?
  showNotifications   Boolean  @default(true)
  logoUrl             String?
  
  // Chaves de API (Configuráveis via Admin)
  rapidApiKey         String?
  pushinpayToken      String?
  pushinpayWebhookToken String?
  perfectPanelUrl     String?
  perfectPanelKey     String?
  
  fbPixelId           String?
  fbApiToken          String?
  updatedAt           DateTime @updatedAt
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  platform    String   @default("instagram") // instagram, tiktok
  type        String   @default("visualizacoes") // seguidores, curtidas, visualizacoes
  packageType String   @default("brasileiros") // brasileiros, mundiais
  viewsAmount Int
  price       Decimal
  originalPrice Decimal?
  isPopular         Boolean  @default(false)
  badge             String?
  providerServiceId String?  // ID do serviço no Duke Fornecedor (ex: 379)
  createdAt         DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model Order {
  id              String      @id @default(cuid())
  instagramUrl    String
  customerEmail   String?     // Novo: Email do cliente
  customerWhatsapp String?    // Novo: WhatsApp do cliente
  amount          Int
  price           Decimal
  status          OrderStatus @default(PENDING)
  pixCode         String?     @db.Text
  pixQrCodeBase64 String?     @db.Text
  paymentId       String?     @unique
  panelOrderId    String?     // ID do pedido retornado pelo PerfectPanel
  plan            Plan        @relation(fields: [planId], references: [id])
  planId          String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model FakeNotification {
  id        String   @id @default(cuid())
  username  String
  message   String
  createdAt DateTime @default(now())
}

enum OrderStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELED
  TRIAL
}
